client
dev tun
proto tcp-client
remote 185.195.13.242 443
fast-io
sndbuf 0
rcvbuf 0
connect-retry 2 300
resolv-retry infinite
nobind
persist-key
persist-tun
remote-cert-tls server
verify-x509-name server_zwyVUrmtibS70tsw name
auth SHA256
auth-nocache
cipher AES-128-GCM
tls-client
tls-version-min 1.2
tls-cipher TLS-ECDHE-ECDSA-WITH-AES-128-GCM-SHA256
ignore-unknown-option block-outside-dns
setenv opt block-outside-dns
verb 3
compress lz4-v2
reneg-sec 0
dhcp-option DNS 1.1.1.1
dhcp-option DNS 8.8.8.8
